---
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";

const API_URL =
  import.meta.env.PUBLIC_SENTINEL_EMBED_URL || "http://127.0.0.1:8000";
const embedUrl = `${API_URL.replace(/\/$/, "")}/dashboard/embed`;

let dashboardHtml = "Errore caricamento simulatore";
try {
  const res = await fetch(embedUrl);
  if (res.ok) {
    dashboardHtml = await res.text();
  } else {
    dashboardHtml = `<p class="text-red-500">Errore caricamento simulatore (Status: ${res.status})</p>`;
  }
} catch {
  dashboardHtml = `
    <div class="rounded-2xl border border-red-200/30 bg-red-950/20 p-6 text-center">
      <p class="text-lg font-bold text-red-400">Backend SentinelGraph offline</p>
      <p class="mt-2 text-sm text-foreground/60">Avvia il server con <code class="rounded bg-muted/50 px-1.5 py-0.5 font-mono text-xs">uvicorn app.main:app --reload</code> sulla porta 8000.</p>
    </div>
  `;
}
---

<Layout
  title={`SentinelGraph | ${SITE.title}`}
  description="Antifraud Live Simulator — model battle, risk metrics, and SentinelGraph demo."
>
  <Header />
  <Main
    pageTitle="SentinelGraph"
    pageDesc="Antifraud lab: dynamic live simulator powered by the Sentinel FastAPI backend."
  >
    <section
      class="space-y-6 border-b border-border/50 pb-8"
      aria-labelledby="sentinel-overview"
    >
      <h2 id="sentinel-overview" class="text-2xl font-semibold tracking-wide">
        Project overview
      </h2>
      <p class="max-w-2xl text-base leading-relaxed text-foreground/70 md:text-lg">
        SentinelGraph compares fraud-detection models beyond raw accuracy — F1,
        recall, and explainability matter when the cost of a missed fraud is
        asymmetric. Avvia il backend locale per usare il simulatore sotto.
      </p>
      <div class="flex flex-wrap gap-3">
        <div
          class="rounded-md border border-border/50 bg-muted/30 px-4 py-2 transition-colors hover:border-accent/50"
        >
          <span class="font-sans text-sm font-bold">Fraud Detection Modeling</span>
        </div>
        <div
          class="rounded-md border border-border/50 bg-muted/30 px-4 py-2 transition-colors hover:border-accent/50"
        >
          <span class="font-sans text-sm font-bold">Statistical learning</span>
        </div>
      </div>
    </section>

    <section class="pt-8" aria-labelledby="sentinel-simulator">
      <h2 id="sentinel-simulator" class="text-2xl font-semibold tracking-wide">
        Live Simulator
      </h2>
      <div
        id="sentinel-simulator-container"
        class="mt-6 min-h-[24rem] overflow-hidden rounded-md border border-border/50 bg-muted/20"
        set:html={dashboardHtml}
      />
    </section>
  </Main>
  <Footer />
</Layout>

<script src="https://unpkg.com/htmx.org@2.0.4" is:inline></script>
<script is:inline>
  function setupSentinelDashboard() {
    const root = document.getElementById("sentinel-simulator-container");
    if (root && window.htmx) {
      window.htmx.process(root);
    }
  }

  document.addEventListener("DOMContentLoaded", setupSentinelDashboard);
  document.addEventListener("astro:page-load", setupSentinelDashboard);
</script>
