---
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";

const API_URL =
  import.meta.env.PUBLIC_SENTINEL_EMBED_URL || "http://127.0.0.1:8000";
const embedUrl = `${API_URL.replace(/\/$/, "")}/dashboard/embed`;

let dashboardHtml = "Errore caricamento simulatore";
try {
  const res = await fetch(embedUrl);
  if (res.ok) {
    dashboardHtml = await res.text();
  } else {
    dashboardHtml = `<p class="text-red-500">Errore caricamento simulatore (Status: ${res.status})</p>`;
  }
} catch {
  dashboardHtml = `
    <div class="rounded-2xl border border-red-200/30 bg-red-950/20 p-6 text-center">
      <p class="text-lg font-bold text-red-400">Backend SentinelGraph offline</p>
      <p class="mt-2 text-sm text-foreground/60">Avvia il server con <code class="rounded bg-muted/50 px-1.5 py-0.5 font-mono text-xs">uvicorn app.main:app --reload</code> sulla porta 8000.</p>
    </div>
  `;
}
---

<Layout
  title={`SentinelGraph | ${SITE.title}`}
  description="Live Anti-Fraud Lab — hybrid MLOps pipeline with heuristic rules, XGBoost, and Autoencoder layers."
>
  <Header />
  <Main
    pageTitle="SentinelGraph: Real-Time Hybrid Fraud Detection"
    pageDesc="Welcome to the Live Anti-Fraud Lab."
  >
    <section
      id="sentinel-overview"
      class="max-w-2xl space-y-6 border-b border-border/50 pb-8"
    >
      <p class="text-base leading-relaxed text-foreground/70 md:text-lg">
        This interactive simulator stress-tests a
        <strong class="font-semibold text-foreground">production-ready MLOps pipeline</strong>
        designed to intercept fraudulent transactions at scale. Instead of relying on a single
        algorithm, SentinelGraph implements a
        <strong class="font-semibold text-foreground">multi-layered hybrid architecture</strong>
        that evaluates and compares three distinct methodology paradigms in real time:
      </p>
      <ol class="list-decimal space-y-3 ps-5 text-base leading-relaxed text-foreground/70 md:text-lg">
        <li>
          <strong class="font-semibold text-foreground">Deterministic Layer:</strong>
          Static heuristic rules for instant edge filtering.
        </li>
        <li>
          <strong class="font-semibold text-foreground">Gradient Boosting Layer:</strong>
          A <strong class="font-semibold text-foreground">XGBoost</strong> classifier
          engineered for tabular feature patterns.
        </li>
        <li>
          <strong class="font-semibold text-foreground">Deep Learning Layer:</strong>
          An unsupervised <strong class="font-semibold text-foreground">Autoencoder</strong> neural
          network dedicated to structural anomaly detection.
        </li>
      </ol>
      <p class="text-base leading-relaxed text-foreground/70 md:text-lg">
        Want to dive deep into the math, data engineering, and architectural decisions behind this
        project? Read the full technical write-up here:
        <a
          href={`${import.meta.env.BASE_URL}/posts/`}
          class="font-semibold text-accent underline decoration-dashed underline-offset-4 hover:opacity-80"
        >
          Architecture &amp; Ideation Deep Dive (RFC)
        </a>.
      </p>
    </section>

    <section class="pt-8" aria-labelledby="sentinel-simulator">
      <h2 id="sentinel-simulator" class="text-2xl font-semibold tracking-wide">
        Live Simulator
      </h2>
      <div
        id="sentinel-simulator-container"
        class="mt-6 min-h-[24rem] overflow-hidden rounded-md border border-border/50 bg-muted/20"
        set:html={dashboardHtml}
      />
    </section>
  </Main>
  <Footer />
</Layout>

<script src="https://unpkg.com/htmx.org@2.0.4" is:inline></script>
<script is:inline>
  function setupSentinelDashboard() {
    const root = document.getElementById("sentinel-simulator-container");
    if (root && window.htmx) {
      window.htmx.config.selfRequestsOnly = false;
      window.htmx.process(root);
    }
  }

  document.addEventListener("DOMContentLoaded", setupSentinelDashboard);
  document.addEventListener("astro:page-load", setupSentinelDashboard);
</script>
